# =============================================================================
# Git Ignore Configuration for Automation Framework
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Files (CRITICAL - NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Test Results & Reports
# -----------------------------------------------------------------------------
test-results/
playwright-report/
allure-results/
html-report/

# -----------------------------------------------------------------------------
# Screenshots & Videos
# -----------------------------------------------------------------------------
error-screenshots/
videos/
*.webm
*.mp4

# -----------------------------------------------------------------------------
# Authentication & Session Files
# -----------------------------------------------------------------------------
storageState.json
auth.json
*.cookies.json

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
coverage/
