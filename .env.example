# ============================================
# Playwright Test Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control
# Add .env to .gitignore

# ============================================
# Application Configuration
# ============================================

# Base URL of the application under test
BASE_URL=https://copilot-student.wowlabz.com

# Test environment (qa, uat, prod)
TEST_ENV=qa

# ============================================
# Credentials (REQUIRED)
# ============================================

# Login credentials - these are required
TEST_USERNAME=your_username_here
TEST_PASSWORD=your_password_here

# ============================================
# CI/CD Configuration
# ============================================

# Set to 'true' when running in CI environment
# CI=true

# ============================================
# Test Execution Options
# ============================================

# Skip authentication (use pre-authenticated state)
# SKIP_AUTH=true

# Run tests in headed mode (default: false for CI)
# HEADLESS=false

# Log level (DEBUG, INFO, WARN, ERROR)
# LOG_LEVEL=INFO

# ============================================
# Browser Options
# ============================================

# Specify browser channel (chrome, msedge)
# BROWSER_CHANNEL=chrome

# ============================================
# Allure Reporting (Optional)
# ============================================

# ALLURE_RESULTS_PATH=allure-results
# ALLURE_REPORT_PATH=allure-report

